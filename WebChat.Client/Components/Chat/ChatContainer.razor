@page "/"
@page "/{Slug}"
@inherits StoreSubscriberComponent
@inject IDispatcher Dispatcher
@inject WebChat.Client.State.SubAgents.SubAgentStore SubAgentStore
@inject WebChat.Client.State.Topics.TopicsStore TopicsStore

<ApprovalModal />

<div class="chat-layout">
    <TopicList />

    <div class="chat-container">
        <MessageList />

        @if (_subAgentCards.Count > 0)
        {
            <div class="subagent-cards">
                @foreach (var handle in _subAgentCards.Keys)
                {
                    <SubAgentCard Handle="@handle" />
                }
            </div>
        }

        <ConnectionStatus />

        <div class="input-area">
            <ChatInput />
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string? Slug { get; set; }

    private bool _initialized;
    private string? _selectedTopicId;
    private IReadOnlyDictionary<string, WebChat.Client.State.SubAgents.SubAgentCardState> _subAgentCards =
        new Dictionary<string, WebChat.Client.State.SubAgents.SubAgentCardState>();

    protected override void OnInitialized()
    {
        Subscribe(TopicsStore.StateObservable,
            state => state.SelectedTopicId,
            topicId =>
            {
                _selectedTopicId = topicId;
                UpdateCards();
            });

        Subscribe(SubAgentStore.StateObservable,
            state => state.Cards,
            _ => UpdateCards());
    }

    private void UpdateCards()
    {
        _subAgentCards = SubAgentStore.State.Cards
            .Where(kv => kv.Value.TopicId == _selectedTopicId)
            .ToDictionary(kv => kv.Key, kv => kv.Value);
    }

    protected override void OnParametersSet()
    {
        var slug = string.IsNullOrEmpty(Slug) ? "default" : Slug;
        Dispatcher.Dispatch(new SelectSpace(slug));

        if (!_initialized)
        {
            _initialized = true;
            Dispatcher.Dispatch(new Initialize());
        }
    }
}
