{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug: Agent",
      "type": "coreclr",
      "request": "attach",
      "processId": 1,
      "preLaunchTask": "debug-agent",
      "pipeTransport": {
        "pipeProgram": "docker",
        "pipeArgs": ["exec", "-i", "agent"],
        "debuggerPath": "/remote_debugger/vsdbg",
        "quoteArgs": false
      },
      "sourceFileMap": {
        "/src": "${workspaceFolder}"
      }
    },
