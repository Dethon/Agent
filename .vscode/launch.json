    {
      "name": "Local: Agent",
      "type": "coreclr",
      "request": "launch",
      "program": "${workspaceFolder}/Agent/bin/Debug/net10.0/Agent.dll",
      "args": ["--chat", "Web", "--reasoning"],
      "cwd": "${workspaceFolder}/Agent",
      "env": {
        "DOTNET_ENVIRONMENT": "Local",
        "ASPNETCORE_ENVIRONMENT": "Local",
        "ASPNETCORE_URLS": "http://localhost:5000"
      }
    },
