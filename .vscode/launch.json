{
  "version": "0.2.0",
  "compounds": [
    {
      "name": "Docker: All Services",
      "configurations": [
        "Docker: Agent",
        "Docker: WebUI",
        "Docker: Observability",
        "Docker: MCP Library",
        "Docker: MCP Vault",
        "Docker: MCP WebSearch",
        "Docker: MCP Idealista",
        "Docker: MCP HomeAssistant",
        "Docker: MCP Sandbox",
        "Docker: MCP Channel SignalR",
        "Docker: MCP Channel Telegram",
        "Docker: MCP Channel ServiceBus",
        "Docker: MCP Channel Voice",
        "Docker: MCP Scheduling",
        "Docker: MCP Printer"
      ],
      "preLaunchTask": "docker-debug-up",
      "stopAll": true
    },
    {
      "name": "Local: All Services",
      "configurations": [
        "Local: Agent",
        "Local: WebUI",
        "Local: Observability",
        "Local: MCP Library",
        "Local: MCP Vault",
        "Local: MCP WebSearch",
        "Local: MCP Idealista",
        "Local: MCP HomeAssistant",
        "Local: MCP Sandbox",
        "Local: MCP Channel SignalR",
        "Local: MCP Channel Telegram",
        "Local: MCP Channel ServiceBus",
        "Local: MCP Channel Voice",
        "Local: MCP Scheduling",
        "Local: MCP Printer"
      ],
      "preLaunchTask": "build-all-local",
      "stopAll": true
    }
  ],
  "configurations": [
    {
      "name": "Docker: Agent",
      "type": "coreclr",
      "request": "attach",
      "processId": 1,
      "pipeTransport": {
        "pipeProgram": "docker",
        "pipeArgs": ["exec", "-i", "agent"],
        "debuggerPath": "/remote_debugger/vsdbg",
        "quoteArgs": false
      },
      "sourceFileMap": {
        "/src": "${workspaceFolder}"
      }
    },
    {
      "name": "Docker: WebUI",
