# Snapcast music client for a nabu satellite. Provisioning rewrites HUBHOST/ROOM/%i/XDGDIR.
# --soundcard music => the softvol PCM in /etc/asound.conf (softvol -> PipeWire -> jack), so the
#                      satellite ducks it via amixer while PipeWire mixes it with TTS/cues.
# XDG_RUNTIME_DIR    => this system service has no login session, so it needs the runtime dir to
#                      reach the user's (lingering) PipeWire that the `music` PCM bridges to.
# --hostID ROOM     => the Music Assistant / Snapcast player name; match it to the HA area slug
#                      so /ha/areas/<room>/ resolves media_player.<room>.
[Unit]
Description=Snapcast music client for nabu satellite (%i)
After=network-online.target sound.target nabu-satellite.service
Wants=network-online.target

[Service]
Environment=XDG_RUNTIME_DIR=XDGDIR
ExecStart=/usr/bin/snapclient --host HUBHOST --port 1704 --hostID ROOM --player alsa --soundcard music
Restart=always
RestartSec=2
User=%i
SupplementaryGroups=audio

[Install]
WantedBy=multi-user.target