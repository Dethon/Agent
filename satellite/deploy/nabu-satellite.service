# Jabra Speak2 (55/75) variant — provisioning rewrites the plughw:0,0 placeholder below to
# plughw:CARD=<name>,DEV=0 (the USB card auto-detected by name; immune to ALSA index churn).
# The mic is 16 kHz mono native (no resampling); plughw resamples only the 22050 Hz playback.
# --wake-playback-ms plays a brief silent buffer through the speaker before opening the mic:
# the Jabra's mic ADC firmware-sleeps when idle and capture-only opens return EIO until the
# speaker stream wakes it (the satellite retries the play+open until capture catches). No button
# (the Jabra's onboard buttons are HID-telephony, unusable on Linux), no LED.
# reSpeaker 2-Mic HAT variant: provision with the device arg plughw:CARD=seeed2micvoicec,DEV=0
# (16 kHz-native, used verbatim) and add --button-gpio 17 --led-spi (APA102s need dtparam=spi=on);
# it doesn't sleep, so --no-wake-playback is fine. Other hardware: a USB foot-switch is
# --button-evdev /dev/input/eventX:<keycode>; a wired indicator is --led-gpio <pin>.
[Unit]
Description=Nabu Rust Wyoming Satellite (%i)
After=network-online.target sound.target
Wants=network-online.target

[Service]
# Pin the performance governor: the steady sub-threshold wake-detection load sits exactly
# where ondemand idles at 600 MHz, roughly doubling per-chunk inference time and adding
# governor-ramp jitter to wake latency. A dedicated satellite Pi trades the extra idle power
# for consistent latency. The `+` prefix runs this as root despite User=%i; `|| true` keeps
# a governor-less kernel from failing the unit.
ExecStartPre=+/bin/sh -c 'for g in /sys/devices/system/cpu/cpufreq/policy*/scaling_governor; do echo performance > "$g" || true; done'
# Tail-latency insurance: background jobs (apt, unattended-upgrades) must not delay the
# 80 ms audio pumps.
Nice=-10
ExecStart=/usr/local/bin/nabu-satellite \
  --listen 0.0.0.0:10700 \
  --mic-command "arecord -D plughw:0,0 -r 16000 -c 1 -f S16_LE -t raw" \
  --snd-command "aplay -D plughw:0,0 -r 22050 -c 1 -f S16_LE -t raw --start-delay=100000 -F 50000" \
  --preroll-ms 1000 \
  --wake-playback-ms 500
Environment=RUST_LOG=info
Restart=always
RestartSec=2
User=%i
# GPIO button/LED need the `gpio` group; a USB/evdev foot-switch needs `input`;
# the HAT's APA102 LEDs need `spi` (spidev nodes are root:spi on Raspberry Pi OS).
SupplementaryGroups=gpio input spi

[Install]
WantedBy=multi-user.target