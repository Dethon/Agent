@inherits LayoutComponentBase
@inject MetricsHubEffect HubEffect

<div class="layout">
    <nav class="sidebar">
        <NavLink href="/" Match="NavLinkMatch.All" class="sidebar-icon" title="Overview">
            <span>&#9673;</span>
        </NavLink>
        <NavLink href="/tokens" class="sidebar-icon" title="Tokens">
            <span>$</span>
        </NavLink>
        <NavLink href="/tools" class="sidebar-icon" title="Tools">
            <span>&#9881;&#xFE0E;</span>
        </NavLink>
        <NavLink href="/memory" class="sidebar-icon" title="Memory">
            <span>&#9670;&#xFE0E;</span>
        </NavLink>
        <NavLink href="/errors" class="sidebar-icon" title="Errors">
            <span>&#9888;&#xFE0E;</span>
        </NavLink>
        <NavLink href="/schedules" class="sidebar-icon" title="Schedules">
            <span>&#9200;&#xFE0E;</span>
        </NavLink>
        <NavLink href="/latency" class="sidebar-icon" title="Latency">
            <span>&#9201;&#xFE0E;</span>
        </NavLink>
        <NavLink href="/voice" class="sidebar-icon" title="Voice">
            <svg width="1.1em" height="1.1em" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M3 9v6h4l5 5V4L7 9H3z" />
                <path d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z" />
            </svg>
        </NavLink>
    </nav>
    <main class="content">
        @Body
    </main>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        try { await HubEffect.StartAsync(); }
        catch
        {
            // ignored
        }
    }
}
