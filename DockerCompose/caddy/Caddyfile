assistants.herfluffness.com {
    tls {
        dns cloudflare {env.CF_API_TOKEN}
    }

    handle /hubs/* {
        reverse_proxy mcp-channel-signalr:8080
    }

    handle /api/agents* {
        reverse_proxy agent:8080
    }

    redir /dashboard /dashboard/ 308

    handle /dashboard/* {
        reverse_proxy observability:8080
    }

    handle {
        reverse_proxy webui:8080
    }
}

