# Docker Compose Environment Variables
# Data directory path
REPOSITORY_PATH=..
DATA_PATH=./volumes/data
VAULT_PATH=./volumes/vault

# User and Group IDs - used by services that need file permissions
PUID=
PGID=

# Mcp secrets
OPENROUTER__APIKEY=
JACKETT__APIKEY=
QBITTORRENT__USERNAME=
QBITTORRENT__PASSWORD=
BRAVESEARCH__APIKEY=
CAPSOLVER__APIKEY=
IDEALISTA__APIKEY=
IDEALISTA__SECRET=

# Service bus secrets
SERVICEBUSCONNECTIONSTRING=

# Telegram secrets
ALLOWEDUSERNAMES__0=
ALLOWEDUSERNAMES__1=
BOTS__0__BOTTOKEN=
BOTS__1__BOTTOKEN=

# SignalR secrets
WEBPUSH__SUBJECT=
WEBPUSH__PUBLICKEY=
WEBPUSH__PRIVATEKEY=

# WebChat user identities
USERS__0__ID=
USERS__0__AVATARURL=
USERS__1__ID=
USERS__1__AVATARURL=

# Cloudflare secrets
CF_API_TOKEN=
 