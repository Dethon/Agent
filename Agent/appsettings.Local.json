{
    "redis": {
        "connectionString": "localhost:6379"
    },
    "agents": [
        {
            "id": "jack",
            "name": "Jack",
            "model": "z-ai/glm-5:nitro",
            "mcpServerEndpoints": [
                "http://localhost:6001/mcp",
                "http://localhost:6003/mcp"
            ],
            "whitelistPatterns": [
                "mcp:*"
            ]
        },
        {
            "id": "jonas",
            "name": "Jonas",
            "model": "z-ai/glm-5:nitro",
            "mcpServerEndpoints": [
                "http://localhost:6002/mcp",
                "http://localhost:6003/mcp",
                "http://localhost:6005/mcp"
            ],
            "enabledFeatures": [
                "scheduling",
                "subagents"
            ],
            "whitelistPatterns": [
                "mcp:*",
                "domain:scheduling:*",
                "domain:subagents:*",
                "domain:memory:*"
            ]
        }
    ],
    "subAgents": [
        {
            "id": "jonas-worker",
            "name": "Jonas Worker",
            "description": "A worker subagent with the same toolset as Jonas for delegating tasks",
            "model": "z-ai/glm-4.7:nitro",
            "mcpServerEndpoints": [
                "http://localhost:6002/mcp",
                "http://localhost:6003/mcp",
                "http://localhost:6005/mcp"
            ],
            "maxExecutionSeconds": 600
        }
    ],
    "channelEndpoints": [
        {
            "channelId": "signalr",
            "endpoint": "http://localhost:6010/mcp"
        },
        {
            "channelId": "telegram",
            "endpoint": "http://localhost:6011/mcp"
        },
        {
            "channelId": "servicebus",
            "endpoint": "http://localhost:6012/mcp"
        }
    ]
}
