{
    "Memory": {
        "Embedding": {
            "Model": "openai/text-embedding-3-small"
        },
        "Extraction": {
            "Model": "openai/gpt-5.4-nano",
            "MaxCandidatesPerMessage": 5,
            "SimilarityThreshold": 0.85,
            "WindowMixedTurns": 6
        },
        "Dreaming": {
            "CronSchedule": "0 3 * * *",
            "Model": "openai/gpt-5.4-nano",
            "DecayDays": 30,
            "DecayFactor": 0.9,
            "DecayFloor": 0.1
        },
        "Recall": {
            "DefaultLimit": 10,
            "IncludePersonalityProfile": true,
            "WindowUserTurns": 3
        }
    },
    "openRouter": {
        "apiUrl": "https://openrouter.ai/api/v1/",
        "apiKey": ""
    },
    "redis": {
        "connectionString": "redis:6379"
    },
    "agents": [
        {
            "id": "jack",
            "name": "Jack",
            "model": "z-ai/glm-5:nitro",
            "mcpServerEndpoints": [
                "http://mcp-library:8080/mcp",
                "http://mcp-websearch:8080/mcp"
            ],
            "enabledFeatures": [
                "filesystem.glob",
                "filesystem.move"
            ],
            "whitelistPatterns": [
                "domain:filesystem:*",
                "mcp:mcp-library:*",
                "mcp:mcp-websearch:*"
            ]
        },
        {
            "id": "jonas",
            "name": "Jonas",
            "model": "z-ai/glm-5:nitro",
            "mcpServerEndpoints": [
                "http://mcp-vault:8080/mcp",
                "http://mcp-websearch:8080/mcp",
                "http://mcp-idealista:8080/mcp"
            ],
            "enabledFeatures": [
                "filesystem",
                "scheduling",
                "subagents",
                "memory"
            ],
            "whitelistPatterns": [
                "domain:filesystem:*",
                "mcp:mcp-vault:*",
                "mcp:mcp-websearch:*",
                "mcp:mcp-idealista:*",
                "domain:scheduling:*",
                "domain:subagents:*",
                "domain:memory:*"
            ]
        }
    ],
    "subAgents": [
        {
            "id": "jonas-worker",
            "name": "Jonas Worker",
            "description": "A worker subagent with the same toolset as Jonas for delegating tasks",
            "model": "z-ai/glm-5:nitro",
            "mcpServerEndpoints": [
                "http://mcp-vault:8080/mcp",
                "http://mcp-websearch:8080/mcp",
                "http://mcp-idealista:8080/mcp"
            ],
            "enabledFeatures": [
                "filesystem"
            ],
            "maxExecutionSeconds": 600
        }
    ],
    "channelEndpoints": [
        {
            "channelId": "signalr",
            "endpoint": "http://mcp-channel-signalr:8080/mcp"
        },
        {
            "channelId": "telegram",
            "endpoint": "http://mcp-channel-telegram:8080/mcp"
        },
        {
            "channelId": "servicebus",
            "endpoint": "http://mcp-channel-servicebus:8080/mcp"
        }
    ],
    "DefaultScheduleChannelId": "signalr",
    "Logging": {
        "LogLevel": {
            "Default": "Warning",
            "System.Net.Http.HttpClient": "Warning"
        }
    }
}
