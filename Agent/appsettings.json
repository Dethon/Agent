{
    "openRouter": {
        "apiUrl": "https://openrouter.ai/api/v1/",
        "apiKey": ""
    },
    "redis": {
        "connectionString": "redis:6379"
    },
    "agents": [
        {
            "id": "jack",
            "name": "Jack",
            "model": "z-ai/glm-5:nitro",
            "mcpServerEndpoints": [
                "http://mcp-library:8080/sse",
                "http://mcp-websearch:8080/sse"
            ],
            "whitelistPatterns": [
                "mcp:mcp-library:*",
                "mcp:mcp-websearch:*"
            ]
        },
        {
            "id": "jonas",
            "name": "Jonas",
            "model": "z-ai/glm-5:nitro",
            "mcpServerEndpoints": [
                "http://mcp-text:8080/sse",
                "http://mcp-websearch:8080/sse",
                "http://mcp-memory:8080/sse",
                "http://mcp-idealista:8080/sse"
            ],
            "enabledFeatures": [
                "scheduling",
                "subagents"
            ],
            "whitelistPatterns": [
                "mcp:mcp-text:*",
                "mcp:mcp-websearch:*",
                "mcp:mcp-memory:*",
                "mcp:mcp-idealista:*",
                "domain:scheduling:*",
                "domain:subagents:*"
            ]
        }
    ],
    "subAgents": [
        {
            "id": "jonas-worker",
            "name": "Jonas Worker",
            "description": "A worker subagent with the same toolset as Jonas for delegating tasks",
            "model": "z-ai/glm-5:nitro",
            "mcpServerEndpoints": [
                "http://mcp-text:8080/sse",
                "http://mcp-websearch:8080/sse",
                "http://mcp-memory:8080/sse",
                "http://mcp-idealista:8080/sse"
            ],
            "maxExecutionSeconds": 600
        }
    ],
    "channelEndpoints": [
        {
            "channelId": "signalr",
            "endpoint": "http://mcp-channel-signalr:8080/sse"
        },
        {
            "channelId": "telegram",
            "endpoint": "http://mcp-channel-telegram:8080/sse"
        },
        {
            "channelId": "servicebus",
            "endpoint": "http://mcp-channel-servicebus:8080/sse"
        }
    ],
    "DefaultScheduleChannelId": "signalr",
    "Logging": {
        "LogLevel": {
            "Default": "Warning",
            "System.Net.Http.HttpClient": "Warning"
        }
    }
}
