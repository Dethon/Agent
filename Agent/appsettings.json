{
  "openRouter": {
    "apiUrl": "https://openrouter.ai/api/v1/",
    "apiKey": ""
  },
  "redis": {
    "connectionString": "redis:6379"
  },
  "agents": [
    {
      "id": "jack",
      "name": "Jack",
      "model": "z-ai/glm-5:nitro",
      "mcpServerEndpoints": [
        "http://mcp-library:8080/sse",
        "http://mcp-websearch:8080/sse"
      ],
      "whitelistPatterns": [
        "mcp:mcp-library:*",
        "mcp:mcp-websearch:*"
      ]
    },
    {
      "id": "jonas",
      "name": "Jonas",
      "model": "z-ai/glm-5:nitro",
      "mcpServerEndpoints": [
        "http://mcp-text:8080/sse",
        "http://mcp-websearch:8080/sse",
        "http://mcp-memory:8080/sse",
        "http://mcp-idealista:8080/sse"
      ],
      "enabledFeatures": [
        "scheduling"
      ],
      "whitelistPatterns": [
        "mcp:mcp-text:*",
        "mcp:mcp-websearch:*",
        "mcp:mcp-memory:*",
        "mcp:mcp-idealista:*",
        "domain:scheduling:*"
      ]
    }
  ],
  "channelEndpoints": [
    { "channelId": "signalr", "endpoint": "http://mcp-channel-signalr:8080/sse" }
//    { "channelId": "telegram", "endpoint": "http://mcp-channel-telegram:8080/sse" },
//    { "channelId": "servicebus", "endpoint": "http://mcp-channel-servicebus:8080/sse" }
  ],
  "DefaultScheduleChannelId": "",
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "System.Net.Http.HttpClient": "Warning"
    }
  }
}
