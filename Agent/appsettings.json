{
    "Memory": {
        "Embedding": {
            "Model": "openai/text-embedding-3-small"
        },
        "Extraction": {
            "Model": "openai/gpt-5.4-nano",
            "MaxCandidatesPerMessage": 5,
            "SimilarityThreshold": 0.85,
            "WindowMixedTurns": 6
        },
        "Dreaming": {
            "CronSchedule": "0 3 * * *",
            "Model": "openai/gpt-5.4-nano",
            "DecayDays": 30,
            "DecayFactor": 0.9,
            "DecayFloor": 0.1
        },
        "Recall": {
            "DefaultLimit": 10,
            "IncludePersonalityProfile": true,
            "WindowUserTurns": 3
        }
    },
    "openRouter": {
        "apiUrl": "https://openrouter.ai/api/v1/",
        "apiKey": "",
        "maxContextTokens": 800000
    },
    "redis": {
        "connectionString": "redis:6379"
    },
    "agents": [
        {
            "id": "jack",
            "name": "Jack",
            "description": "Download assistant (library/torrent search and downloads).",
            "model": "z-ai/glm-5.2",
            "reasoningEffort": "low",
            "mcpServerEndpoints": [
                "http://mcp-library:8080/mcp",
                "http://mcp-websearch:8080/mcp"
            ],
            "enabledFeatures": [
                "filesystem.glob",
                "filesystem.move",
                "filesystem.info",
                "filesystem.read",
                "filesystem.remove"
            ],
            "whitelistPatterns": [
                "domain__filesystem*",
                "mcp__mcp-library*",
                "mcp__mcp-websearch*"
            ]
        },
        {
            "id": "jonas",
            "name": "Jonas",
            "description": "General-purpose personal assistant (vault notes, web search, real-estate, home automation).",
            "model": "z-ai/glm-5.2:nitro",
            "reasoningEffort": "medium",
            "mcpServerEndpoints": [
                "http://mcp-vault:8080/mcp",
                "http://mcp-sandbox:8080/mcp",
                "http://mcp-websearch:8080/mcp",
                "http://mcp-idealista:8080/mcp",
                "http://mcp-homeassistant:8080/mcp",
                "http://mcp-scheduling:8080/mcp",
                "http://mcp-printer:8080/mcp"
            ],
            "enabledFeatures": [
                "filesystem",
                "subagents",
                "memory"
            ],
            "whitelistPatterns": [
                "domain__filesystem*",
                "mcp__mcp-websearch*",
                "mcp__mcp-idealista*",
                "domain__subagents*",
                "domain__memory*"
            ]
        },
        {
            "id": "nabu",
            "name": "Nabu",
            "description": "Voice-optimized assistant: replies are read aloud, so answers are brief and free of formatting.",
            "model": "z-ai/glm-5.1:nitro",
            "reasoningEffort": "none",
            "customInstructions": "You are speaking over a voice interface; always use the same language the user is using; every reply is read aloud by text-to-speech. \n\n IMPORTANT — BREVITY IS ESSENTIAL: Keep answers SUPER brief, if something can be said with one word don't use two — and give ONLY the detail the user actually asked for. Use plain spoken prose: never use emojis, markdown, bullet points, headings, or code blocks, since none of that can be spoken. Never use abbreviations, unit symbols, or acronyms — for example 'km/s', '°C', 'USA' or 'EEUU' — always spell out the full words instead (such as 'kilómetros por segundo', 'grados Celsius' or 'Estados Unidos'), in the user's language, because text-to-speech would mangle them otherwise.\n\nIMPORTANT — ACKNOWLEDGE BEFORE MULTI-STEP WORK: If you are going to need more than one tool calling turns, your very first output must be a short spoken acknowledgement in the user's language (for example 'Buscando' or 'Procesando'), written as plain text before any tool call; then run the tools and speak the answer once they return. If you can answer in a single tool calling turn, reply directly — no acknowledgement needed.",
            "mcpServerEndpoints": [
                "http://mcp-vault:8080/mcp",
                "http://mcp-sandbox:8080/mcp",
                "http://mcp-websearch:8080/mcp",
                "http://mcp-idealista:8080/mcp",
                "http://mcp-homeassistant:8080/mcp",
                "http://mcp-scheduling:8080/mcp",
                "http://mcp-printer:8080/mcp",
                "http://mcp-channel-voice:8080/mcp"
            ],
            "enabledFeatures": [
                "filesystem",
                "subagents",
                "memory"
            ],
            "whitelistPatterns": [
                "domain__filesystem*",
                "mcp__mcp-websearch*",
                "mcp__mcp-idealista*",
                "domain__subagents*",
                "domain__memory*"
            ]
        }
    ],
    "subAgents": [
        {
            "id": "jonas-worker",
            "name": "Jonas Worker",
            "description": "A worker subagent with the same toolset as Jonas for delegating tasks",
            "model": "z-ai/glm-5.2:nitro",
            "reasoningEffort": "medium",
            "mcpServerEndpoints": [
                "http://mcp-vault:8080/mcp",
                "http://mcp-sandbox:8080/mcp",
                "http://mcp-websearch:8080/mcp",
                "http://mcp-idealista:8080/mcp",
                "http://mcp-homeassistant:8080/mcp"
            ],
            "enabledFeatures": [
                "filesystem"
            ],
            "maxExecutionSeconds": 1800
        }
    ],
    "channelEndpoints": [
        {
            "channelId": "signalr",
            "endpoint": "http://mcp-channel-signalr:8080/mcp"
        },
        {
            "channelId": "telegram",
            "endpoint": "http://mcp-channel-telegram:8080/mcp"
        },
        {
            "channelId": "servicebus",
            "endpoint": "http://mcp-channel-servicebus:8080/mcp"
        },
        {
            "channelId": "scheduling",
            "endpoint": "http://mcp-scheduling:8080/mcp"
        },
        {
            "channelId": "voice",
            "endpoint": "http://mcp-channel-voice:8080/mcp",
            "attachOnly": true
        },
        {
            "channelId": "library",
            "endpoint": "http://mcp-library:8080/mcp"
        }
    ],
    "Logging": {
        "LogLevel": {
            "Default": "Warning",
            "System.Net.Http.HttpClient": "Warning"
        }
    }
}
